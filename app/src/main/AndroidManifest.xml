<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- A conversão de um filme leva quase uma hora entre upload, recodificação e download. Sem um
         foreground service o Android mata o processo assim que o app sai de cena. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!--
         O ícone fica em res/drawable, NÃO em res/mipmap: o Fire OS 7 tem um bug conhecido e simplesmente
         não lê ícones de mipmap para apps instalados fora da loja — foi por isso que a grade do Fire TV
         insistia num ícone velho por mais que se reinstalasse. E o banner (1280x720) só vale para apps
         publicados na Appstore: ele é enviado na submissão, não sai do APK. Para um app sideloaded, o que
         a TV mostra é este ícone.
    -->
    <application
        android:name=".RenaPlayApplication"
        android:allowBackup="true"
        android:banner="@drawable/app_banner"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.RenaPlay"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:banner="@drawable/app_banner"
            android:icon="@drawable/ic_launcher"
            android:logo="@drawable/ic_launcher"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".setup.ServerSetupActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".browse.BrowseActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".detail.DetailActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".detail.EpisodesActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".player.PlaybackActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="false" />

        <activity
            android:name=".subtitles.SubtitleSearchActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".settings.SettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <activity
            android:name=".pairing.PairingActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <service
            android:name=".conversion.ConversionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
