<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:background="@drawable/media_card_background"
    android:padding="4px">

    <FrameLayout
        android:layout_width="300px"
        android:layout_height="450px">

        <ImageView
            android:id="@+id/card_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <View
            android:id="@+id/card_progress_track"
            android:layout_width="match_parent"
            android:layout_height="4px"
            android:layout_gravity="bottom"
            android:background="#66FFFFFF"
            android:visibility="gone" />

        <View
            android:id="@+id/card_progress_fill"
            android:layout_width="0px"
            android:layout_height="4px"
            android:layout_gravity="bottom|left"
            android:background="@color/rena_accent"
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/card_title"
        android:layout_width="300px"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/rena_text_primary"
        android:textSize="16sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/card_subtitle"
        android:layout_width="300px"
        android:layout_height="wrap_content"
        android:textColor="@color/rena_text_secondary"
        android:textSize="11sp"
        android:textAllCaps="true"
        android:letterSpacing="0.15"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>
