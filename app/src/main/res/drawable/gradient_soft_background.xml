<?xml version="1.0" encoding="utf-8"?>
<!-- Ambient 4-blob glow, ported from the web app's gradient-soft token. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/rena_background" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="480dp"
                android:centerX="0.15"
                android:centerY="0.05"
                android:startColor="#8CFF7A2F"
                android:endColor="#00160F1E" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="480dp"
                android:centerX="0.9"
                android:centerY="0.2"
                android:startColor="#8CFF3D7F"
                android:endColor="#00160F1E" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="480dp"
                android:centerX="0.6"
                android:centerY="0.9"
                android:startColor="#804CC9FF"
                android:endColor="#00160F1E" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="480dp"
                android:centerX="0.2"
                android:centerY="0.95"
                android:startColor="#809B5CFF"
                android:endColor="#00160F1E" />
        </shape>
    </item>
</layer-list>
